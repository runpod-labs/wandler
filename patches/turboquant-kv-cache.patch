 .../group_query_attention_turboquant_impl.cu  | 34 ++++++++++++++-----
 1 file changed, 25 insertions(+), 9 deletions(-)

diff --git a/onnxruntime/contrib_ops/cuda/bert/group_query_attention_turboquant_impl.cu b/onnxruntime/contrib_ops/cuda/bert/group_query_attention_turboquant_impl.cu
