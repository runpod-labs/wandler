@@ -904,10 +904,16 @@ __global__ void TQFlashAttentionWmmaKernel(
     if (tid < tile_n) {
       const int row_off = (b * num_kv_heads + h_kv) * total_seq * kHeadDim
                         + (tile + tid) * kHeadDim;
+      // Vectorised uint4 (8-fp16) loads — see v4-lite kernel comment.
+      static_assert(kHeadDim % 8 == 0, "vectorised load needs kHeadDim divisible by 8");
+      const uint4* k_v4 = reinterpret_cast<const uint4*>(k_full + row_off);
+      const uint4* v_v4 = reinterpret_cast<const uint4*>(v_full + row_off);
+      uint4* smem_k_v4 = reinterpret_cast<uint4*>(&smem_k[tid][0]);
+      uint4* smem_v_v4 = reinterpret_cast<uint4*>(&smem_v[tid][0]);
       #pragma unroll
-      for (int i = 0; i < kHeadDim; ++i) {
-        smem_k[tid][i] = k_full[row_off + i];
-        smem_v[tid][i] = v_full[row_off + i];
+      for (int i = 0; i < kHeadDim / 8; ++i) {
+        smem_k_v4[i] = k_v4[i];
+        smem_v_v4[i] = v_v4[i];
       }
     }
     __syncthreads();
@@ -1051,12 +1057,22 @@ __global__ void TQFlashAttentionKernel(
     const int tile_end = min(tile + kBlockK, total_seq);
     const int tile_n = tile_end - tile;
 
-    // Load K_tile and V_tile.  Each thread copies one column for every row.
-    if (tid < kHeadDim) {
-      for (int s = 0; s < tile_n; ++s) {
-        const int row_off = k_base + (tile + s) * kHeadDim;
-        smem_k[s][tid] = k_full[row_off + tid];
-        smem_v[s][tid] = v_full[row_off + tid];
+    // Load K_tile and V_tile.  Vectorised: each thread loads ONE full row
+    // via uint4 (16-byte = 8-fp16 per transaction). Compared to the older
+    // "thread tid loads column tid for every row" pattern, this reduces
+    // HBM transactions by ~8x at hd=64 and turns the load into a single
