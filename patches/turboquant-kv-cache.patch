-  // TurboQuant branch — Option A graph rewrite added codebook/hadamard
-  // inputs at slots 14/15 and set kv_quant_method=turboquant.  Run encode +
-  // (decode if past) + standard FA on the resulting fp16 K/V.
+  Tensor qSplit;
+  Tensor kSplit;
