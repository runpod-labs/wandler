+  auto align256 = [](size_t v) -> size_t { return ((v + 255) / 256) * 256; };
+  const size_t q_bnsh_bytes = align256(Bs * N_q * S_q * Hs * sizeof(T));
+  const size_t y_bnsh_bytes = align256(Bs * N_q * S_q * Hs * sizeof(T));
