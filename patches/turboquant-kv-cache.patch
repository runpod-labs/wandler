+// Copyright (c) Microsoft Corporation. All rights reserved.
+// Licensed under the MIT License.
+
+#param head_dim
+#param key_bits
+#param tile_size
+#param norm_correction
+
+// TurboQuant decode-time Q.K^T shader (rotated-space).
+//
+// Computes attention scores for q_len == 1, the decode case:
+//
+//   q_rot = q @ H        // computed once per (batch, q_head) at workgroup start
+//   for each cached token i:
+//     y_hat = centroids[indices[i]]         // gather from constant LUT
+//     score[i] = vec_norm[i] * dot(q_rot, y_hat) * scale
+//
+// The K cache is read in packed form. We never reconstruct K in original space.
+//
+// Workgroup layout: one workgroup per (batch, q_head, token_tile).
+// tile_size tokens per workgroup; head_dim threads cooperate per token.
+//
+// Inputs:
+//   q: array<f16> (B*H_q*D)
+//   key_cache: array<u32> packed slot bytes
+//   k_centroids: array<f16> (2^key_bits)
+//   seqlens_k: array<u32> (B,)
+// Output:
+//   scores: array<f32> (B*H_q*S)
+
+const HEAD_DIM: u32 = head_dim;
+const KEY_CENTROIDS: u32 = 1u << key_bits;
+const PACKED_K_BYTES: u32 = (HEAD_DIM * key_bits + 7u) / 8u;
+const KEY_SLOT_BYTES: u32 = PACKED_K_BYTES + 2u;  // +2 for vec_norm fp16
+
+var<workgroup> q_rot: array<f32, head_dim>;
+var<workgroup> centroids: array<f32, 16>;  // upper bound for kKeyBits<=4
+
+fn unpack_4bit_lo(byte: u32) -> u32 { return byte & 0xFu; }
+fn unpack_4bit_hi(byte: u32) -> u32 { return (byte >> 4u) & 0xFu; }
+
+// Read a single byte at byte_offset from a u32 array view of the cache buffer.
+fn read_byte(byte_offset: u32) -> u32 {
+  let u32_idx = byte_offset / 4u;
+  let bit_off = (byte_offset % 4u) * 8u;
+  return (key_cache[u32_idx] >> bit_off) & 0xFFu;
+}
+
+fn read_3byte_group(byte_offset: u32) -> u32 {
+  // Returns a 24-bit word in the low bits.
+  return read_byte(byte_offset) |
+         (read_byte(byte_offset + 1u) << 8u) |
+         (read_byte(byte_offset + 2u) << 16u);
+}
+
+$MAIN {
+  let tid = local_idx;
+  let token_tile = workgroup_idx % uniforms.num_token_tiles;
+  let bh = workgroup_idx / uniforms.num_token_tiles;
+  let q_head = bh % uniforms.n_q_heads;
+  let batch_idx = bh / uniforms.n_q_heads;
+
+  let kv_head = q_head / uniforms.q_heads_per_kv;
+  let seq_len = seqlens_k[batch_idx];
+
+  // 1. Load Q for this head and apply Hadamard rotation.
+  if (tid < HEAD_DIM) {
+    q_rot[tid] = f32(q[(batch_idx * uniforms.n_q_heads + q_head) * HEAD_DIM + tid]);
+  }
+  if (tid < KEY_CENTROIDS) {
+    centroids[tid] = f32(k_centroids[tid]);
+  }
+  workgroupBarrier();
+
+  // FWHT.
+  var h: u32 = 1u;
+  loop {
+    if (h >= HEAD_DIM) { break; }
+    if (tid < HEAD_DIM / 2u) {
+      let pair = (tid / h) * 2u * h + (tid % h);
+      let a = q_rot[pair];
+      let b = q_rot[pair + h];
+      q_rot[pair] = a + b;
+      q_rot[pair + h] = a - b;
+    }
+    workgroupBarrier();
+    h = h * 2u;
+  }
+  let inv_sqrt_d = inverseSqrt(f32(HEAD_DIM));
+  if (tid < HEAD_DIM) {
+    q_rot[tid] = q_rot[tid] * inv_sqrt_d;
+  }
+  workgroupBarrier();
+
+  // 2. For each token in this tile, gather centroids and compute the dot.
+  let tokens_per_tile = tile_size;
+  let token_base = token_tile * tokens_per_tile;
+
+  for (var t: u32 = 0u; t < tokens_per_tile; t = t + 1u) {
+    let s = token_base + t;
+    if (s >= seq_len) { break; }
+
+    let slot_byte_off =
+        ((batch_idx * uniforms.n_kv_heads + kv_head) * uniforms.max_seq_len + s) * KEY_SLOT_BYTES;
+
+    // Cooperative dot-product across HEAD_DIM threads.
+    var partial_dot: f32 = 0.0;
+    var partial_csq: f32 = 0.0;
+
+    if (key_bits == 4) {
+      // Each thread handles two D dims (= one byte).
+      if (tid < HEAD_DIM / 2u) {
+        let byte = read_byte(slot_byte_off + tid);
+        let lo = unpack_4bit_lo(byte);
+        let hi = unpack_4bit_hi(byte);
+        let c_lo = centroids[lo];
+        let c_hi = centroids[hi];
+        partial_dot = q_rot[2u * tid] * c_lo + q_rot[2u * tid + 1u] * c_hi;
+        partial_csq = c_lo * c_lo + c_hi * c_hi;
+      }
+    } else if (key_bits == 3) {
+      // Each thread handles 8 D dims (= one 3-byte group). HEAD_DIM/8 threads active.
+      if (tid < HEAD_DIM / 8u) {
+        let word = read_3byte_group(slot_byte_off + tid * 3u);
+        for (var j: u32 = 0u; j < 8u; j = j + 1u) {
+          let idx = (word >> (j * 3u)) & 0x7u;
+          let c = centroids[idx];
+          partial_dot = partial_dot + q_rot[tid * 8u + j] * c;
+          partial_csq = partial_csq + c * c;
+        }
+      }
+    }
+
+    // Reduce partial_dot across threads.
+    reduction[tid] = partial_dot;
+    workgroupBarrier();
+    var stride = HEAD_DIM / 2u;
+    loop {
+      if (stride == 0u) { break; }
+      if (tid < stride) {
+        reduction[tid] = reduction[tid] + reduction[tid + stride];
+      }
+      workgroupBarrier();
+      stride = stride / 2u;
+    }
+    let dot = reduction[0];
+
+    var norm_corr: f32 = 1.0;
+    #if norm_correction
+      reduction[tid] = partial_csq;
+      workgroupBarrier();
+      stride = HEAD_DIM / 2u;
+      loop {
+        if (stride == 0u) { break; }
+        if (tid < stride) {
+          reduction[tid] = reduction[tid] + reduction[tid + stride];
+        }
+        workgroupBarrier();
+        stride = stride / 2u;
+      }
+      norm_corr = inverseSqrt(reduction[0]);
+    #endif
+
+    // Read vec_norm fp16 right after the packed bytes.
+    let norm_byte_off = slot_byte_off + PACKED_K_BYTES;
+    let norm_u32 = key_cache[norm_byte_off / 4u];
+    let norm_bit_off = (norm_byte_off % 4u) * 8u;
+    let half_bits = (norm_u32 >> norm_bit_off) & 0xFFFFu;
+    let vec_norm = unpack2x16float(half_bits).x;
+
+    if (tid == 0u) {
+      let score = dot * norm_corr * vec_norm * uniforms.scale;
+      scores[((batch_idx * uniforms.n_q_heads + q_head) * uniforms.max_seq_len) + s] = score;
+    }
+    workgroupBarrier();
+  }
+}
