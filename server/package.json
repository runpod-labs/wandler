{
  "name": "wandler",
  "version": "2.5.0",
  "description": "transformers.js inference server — OpenAI-compatible API for ONNX models",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runpod-labs/wandler.git"
  },
  "keywords": [
    "inference",
    "transformers.js",
    "onnx",
    "openai",
    "llm",
    "webgpu",
    "server"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "wandler": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "registry"
  ],
  "scripts": {
    "start": "node dist/cli.js",
    "dev": "tsx --watch src/cli.ts",
    "build": "tsc && npm run catalog:build",
    "catalog:build": "tsx scripts/build-catalog.ts",
    "prepublishOnly": "cp ../README.md . && npm run build",
    "typecheck": "tsc --noEmit",
    "benchmark": "node --expose-gc --import tsx/esm src/benchmark.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@huggingface/transformers": "^4.2.0",
    "commander": "^14.0.3",
    "hono": "^4.7.11",
    "onnxruntime-node": "^1.24.3"
  },
  "overrides": {
    "onnxruntime-node": "^1.24.3"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@types/node": "^25.6.0",
    "ai": "^6.0.158",
    "openai": "^6.34.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
